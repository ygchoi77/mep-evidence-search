{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "mep-evidence-ai",
  "main": "worker/index.mjs",
  "compatibility_date": "2026-07-18",
  "workers_dev": true,
  "vars": {
    "OPENAI_MODEL": "gpt-5.6-terra",
    "ALLOWED_ORIGINS": "https://ygchoi77.github.io,http://localhost:5173,http://127.0.0.1:5173"
  },
  "ratelimits": [
    {
      "name": "AI_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 10,
        "period": 60
      }
    }
  ]
}
